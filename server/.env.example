# Copy this to server/.env and fill in values.
# The server loads the first one it finds; if ANTHROPIC_API_KEY is set it uses
# Claude, otherwise it falls back to a local Ollama instance.

# Anthropic Claude backend
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Ollama fallback (default)
# OLLAMA_MODEL=llama3.2:latest

# Server network
# PORT=3000
